# =============================================================================
# Homelab Local Rules — Parental Controls
# =============================================================================
# SID ranges:
#   9001001–9001999  Adult content — DNS query
#   9002001–9002999  Adult content — TLS SNI (HTTPS)
#   9003001–9003999  VPN / proxy bypass attempts
#
# Pattern: dotprefix prevents substring matches.
#   content:".pornhub.com" with dotprefix matches pornhub.com and
#   www.pornhub.com but NOT notpornhub.com.
#
# classtype:policy-violation sets suricata.eve.alert.category so that alerts
# appear correctly in the Kibana [Filebeat Suricata] Alert Overview dashboard.
#
# Deploy: copy to /etc/suricata/rules/local.rules on VM 102, then add to
# rule-files in /etc/suricata/suricata.yaml and reload with:
#   sudo systemctl reload suricata
# =============================================================================

# -----------------------------------------------------------------------------
# ADULT CONTENT — Tube sites (DNS)
# -----------------------------------------------------------------------------
alert dns any any -> any any (msg:"[PARENTAL] Adult DNS pornhub.com"; dns.query; dotprefix; content:".pornhub.com"; nocase; classtype:policy-violation; sid:9001001; rev:2;)
alert dns any any -> any any (msg:"[PARENTAL] Adult DNS xvideos.com"; dns.query; dotprefix; content:".xvideos.com"; nocase; classtype:policy-violation; sid:9001002; rev:2;)
